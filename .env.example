# ⚡ Traffic Harvester — Configuration File
# Copy file ini menjadi ".env" dan isi konfigurasinya sesuai kebutuhan.
# JANGAN PERNAH MENYIMPAN ATAU MENG-COMMIT FILE ".env" KE GIT REPOSITORY!

# ── 1. SERVER CONFIGURATION ──────────────────────────────────────────────────
# Port internal untuk API server & dashboard.
# Di hosting modern seperti Render/Heroku/Railway, variabel ini akan di-inject secara otomatis.
PORT=3000

# ── 2. DATABASE CONFIGURATION (PostgreSQL / Supabase) ──────────────────────────
# Gunakan URL koneksi pooler Supabase (IPv4) jika hosting Anda tidak mendukung IPv6.
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
# REKOMENDASI: Gunakan port 5432 (aws pooler) untuk koneksi handal bebas error ENETUNREACH.
DATABASE_URL=

# Maksimum koneksi yang diperbolehkan di connection pool database (default: 10)
DB_MAX_CONNECTIONS=

# ── 3. WHATSAPP BOT CONFIGURATION (Baileys) ──────────────────────────────────
# Nama tampilan bot Anda yang muncul di logger.
BOT_NAME=

# Nomor WhatsApp Anda sebagai pemilik (Whitelisting).
# PENTING: Gunakan format nomor internasional penuh TANPA karakter '+' atau spasi,
# dan akhiri dengan "@s.whatsapp.net" (Contoh: 6281228264631@s.whatsapp.net).
OWNER_NUMBER=

# Delay dalam milidetik sebelum bot mencoba menyambung ulang jika terputus (default: 5000)
BOT_RECONNECT_DELAY=5000

# ── 4. N8N WEBHOOK INTEGRATION ──────────────────────────────────────────────
# URL webhook production n8n tujuan pengiriman pesan dari bot.
N8N_WEBHOOK_URL=

# Batas waktu timeout request ke webhook n8n (milidetik)
N8N_WEBHOOK_TIMEOUT=10000

# Jumlah percobaan kirim ulang jika webhook n8n gagal merespon (retry logic)
N8N_WEBHOOK_RETRIES=3

# ── 5. AUTHENTICATION & SECURITY ─────────────────────────────────────────────
# Kunci rahasia untuk enkripsi token login (JWT) pada dashboard Traffic Harvester.
# ⚠️ PENTING: Ganti dengan string acak dan panjang saat dideploy di Production!
JWT_SECRET=

# ── 6. SCRAPER CONFIGURATION (Playwright) ────────────────────────────────────
# Jalur executable file browser Chromium untuk Playwright.
# Di lingkungan Docker / Alpine Linux, set ke "/usr/bin/chromium-browser"
# Di sistem Windows lokal, kosongkan saja agar mendeteksi browser bawaan.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=

# ── 7. SYSTEM LOGGING ────────────────────────────────────────────────────────
# Level detail logging (debug, info, warn, error)
LOG_LEVEL=info
